# Ignore git and editor/OS junk
.git
.git/*
.gitignore
.githooks
.githooks/*
.helmignore
.DS_Store
.idea
.vscode

# Ignore CI/test/support files to keep chart payload small
.github
.github/*
INTEGRATION_TESTS.md
tests
tests/*
tests/values/integration
tests/values/integration/*
charts/*/tests
charts/*/tests/*
scripts
scripts/*
docs
docs/*

# Ignore local package files and archives
*.tgz
*.tar.gz

# Optional: ignore node/python build dirs
node_modules
venv
.env*

# Keep top-level docs in the chart package, except hook notes
README_hook.md
RELEASE.md
