#!/usr/bin/env bash
# Pre-commit: two-phase Helm checks with emoji/ASCII toggle (Bash 3+ compatible)
# Phase 1: Sync locks (helm dependency build/update) for ALL charts; stage Chart.lock changes
# Phase 2: Lint + Unit tests for ALL charts
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Emoji toggle:
#   USE_EMOJI=1  (default) → show icons
#   USE_EMOJI=0           → plain ASCII
set -euo pipefail

# Optional debug tracing
DEBUG_HOOK=${DEBUG_HOOK:-0}
if [[ "${DEBUG_HOOK}" == "1" ]]; then
  set -x
fi

# Surface failures that otherwise exit silently under -e
trap 'say "❌" "ERR" "Pre-commit failed at line ${LINENO}: ${BASH_COMMAND}"' ERR

# -------- Output helpers (emoji/ASCII) --------
USE_EMOJI=${USE_EMOJI:-1}
say() {
  local emoji="$1"; local ascii="$2"; shift 2
  if [ "${USE_EMOJI}" = "1" ]; then
    printf "%s %s\n" "${emoji}" "$*"
  else
    printf "%s %s\n" "${ascii}" "$*"
  fi
}

# -------- Bypass hook quickly if requested --------
if [[ "${SKIP_HELM_HOOKS:-}" == "1" ]]; then
  say "🔕" "--" "Skipping Helm pre-commit (SKIP_HELM_HOOKS=1)"
  exit 0
fi

# -------- Ensure we're in a git repo --------
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "${repo_root}" ]]; then
  exit 0
fi
cd "${repo_root}"

# -------- Tool presence checks --------
if ! command -v helm >/dev/null 2>&1; then
  say "⚠️" "WARN" "Helm not found; skipping Helm checks. Install: https://helm.sh/docs/intro/install/"
  exit 0
fi

if ! helm plugin list 2>/dev/null | awk '{print $1}' | grep -qx 'unittest'; then
  say "❌" "ERR" "helm-unittest plugin missing."
  echo "   Install once:  helm plugin install https://github.com/helm-unittest/helm-unittest"
  exit 1
fi

# -------- Discover chart directories --------
# Find tracked Chart.yaml (root + subcharts), exclude vendored deps under */charts/*/charts/*
charts=()
while IFS= read -r f; do
  d="$(dirname "$f")"
  # de-duplicate
  already=0
  for c in "${charts[@]}"; do
    if [[ "$c" == "$d" ]]; then already=1; break; fi
  done
  [[ $already -eq 0 ]] && charts+=("$d")
done < <(git ls-files -- '**/Chart.yaml' 'Chart.yaml' | grep -vE '/charts/[^/]+/charts/')

if [[ ${#charts[@]} -eq 0 ]]; then
  say "ℹ️" "INFO" "No charts found; skipping."
  exit 0
fi

say "🔎" "--" "Found ${#charts[@]} chart(s): ${charts[*]}"

# -------- Version bump + CHANGELOG checks --------
say "🧭" "CHK" "Version/changelog checks"

version_line_changed() {
  # returns 0 if the version line changed in the staged diff
  if git diff --cached -- "$1" | grep -E '^[+-][[:space:]]*version:' >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

changelog_has_version() {
  # $1=changelog file, $2=version
  if grep -Eq "^##[[:space:]]+\\[?${2}\\]?([[:space:]]|$)" "$1"; then
    return 0
  fi
  return 1
}

# Returns 0 if relpath is ignored by chart_dir/.helmignore
is_ignored_by_helmignore() {
  local chart_dir="$1"
  local relpath="$2"
  local ignore_file="$chart_dir/.helmignore"
  [[ -f "$ignore_file" ]] || return 1
  if (cd "$chart_dir" && printf '%s\n' "$relpath" | GIT_CONFIG_GLOBAL=/dev/null GIT_CONFIG_SYSTEM=/dev/null git -c core.excludesFile="$ignore_file" check-ignore -q --no-index --stdin); then
    return 0
  fi
  return 1
}

add_unique() {
  # $1=array name, $2=value
  local arr_name="$1"
  local value="$2"
  local found=0
  eval "for v in \"\${${arr_name}[@]}\"; do if [[ \"\$v\" == \"${value}\" ]]; then found=1; fi; done" || true
  if [[ $found -eq 0 ]]; then
    eval "${arr_name}+=(\"${value}\")"
  fi
}

# -------- Isolated Helm sandbox --------
global_helm_plugins="$(helm env HELM_PLUGINS 2>/dev/null | tr -d '"')"
helm_sandbox="${repo_root}/.helm-hook"
mkdir -p "${helm_sandbox}/config" "${helm_sandbox}/cache" "${helm_sandbox}/data"
export HELM_CONFIG_HOME="${helm_sandbox}/config"
export HELM_CACHE_HOME="${helm_sandbox}/cache"
export HELM_DATA_HOME="${helm_sandbox}/data"
if [[ -n "${global_helm_plugins}" ]]; then
  export HELM_PLUGINS="${global_helm_plugins}"
fi

external_repo_urls=()
while IFS= read -r repo; do
  [[ -z "${repo}" ]] && continue
  case "${repo}" in
    file://*|alias:*|@*) continue ;;
  esac
  add_unique external_repo_urls "${repo}"
done < <(awk '/repository:/{print $2}' Chart.yaml charts/*/Chart.yaml 2>/dev/null | tr -d '"' | sort -u)

if [[ ${#external_repo_urls[@]} -gt 0 ]]; then
  say "🔒" "--" "Using isolated Helm sandbox at ${helm_sandbox}"
  repo_index=0
  for repo in "${external_repo_urls[@]}"; do
    repo_index=$((repo_index + 1))
    helm repo add "hook-${repo_index}" "${repo}" >/dev/null
  done
  helm repo update >/dev/null
else
  say "🔒" "--" "Using isolated Helm sandbox at ${helm_sandbox} (file dependencies only)"
fi

# Ensure each chart version exists in its CHANGELOG
for c in "${charts[@]}"; do
  chart_yaml="${c}/Chart.yaml"
  chart_version="$(awk '/^version:/{print $2; exit}' "$chart_yaml" | sed -E 's/^v//')"
  if [[ "$c" == "." ]]; then
    changelog="CHANGELOG.md"
  else
    changelog="${c}/CHANGELOG.md"
  fi
  if [[ ! -f "$changelog" ]]; then
    say "❌" "ERR" "Missing CHANGELOG: $changelog"
    exit 1
  fi
  if ! changelog_has_version "$changelog" "$chart_version"; then
    say "❌" "ERR" "CHANGELOG entry missing for ${c}: ${chart_version}"
    exit 1
  fi
done

say "ℹ️" "INFO" "Skipping local version bump enforcement. Release tags enforce version bumps against the previous release."

# -------- Phase 1: Sync locks --------
locks_updated=0
for c in "${charts[@]}"; do
  [[ -d "$c" ]] || continue
  say "▶" ">>" "Sync: $c"
  if (cd "$c" && helm dependency build); then
    say "✓" "OK" "Dependencies OK"
  else
    say "↻" "UPD" "Lock out of sync → helm dependency update"
    (cd "$c" && helm dependency update && helm dependency build)
    if [[ -f "$c/Chart.lock" ]]; then
      if ! git diff --quiet -- "$c/Chart.lock"; then
        git add "$c/Chart.lock"
        locks_updated=1
        say "📦" "ADD" "Staged $c/Chart.lock"
      fi
    fi
  fi
done

# -------- Phase 2: Lint + Unit tests --------
for c in "${charts[@]}"; do
  [[ -d "$c" ]] || continue
  say "🧪" "TEST" "Check: $c"
  lint_values_arg=""
  if [[ -f "$repo_root/values.skip-secret-validation.yaml" ]]; then
    lint_values_arg="-f $repo_root/values.skip-secret-validation.yaml"
  fi
  (cd "$c" && helm lint . ${lint_values_arg})
  if [[ "$c" == "." ]]; then
    (cd "$c" && helm unittest --with-subchart=false --strict .)
  else
    (cd "$c" && helm unittest --strict .)
  fi
done

if [[ $locks_updated -eq 1 ]]; then
  say "✅" "OK" "Pre-commit complete: locks synced (staged), lint & tests passed."
else
  say "✅" "OK" "Pre-commit complete: locks already in sync; lint & tests passed."
fi
